# Normalize line endings and declare UTF-8 for source text
* text=auto eol=lf

*.js   text eol=lf
*.mjs  text eol=lf
*.cjs  text eol=lf
*.html text eol=lf
*.css  text eol=lf
*.json text eol=lf
*.md   text eol=lf
*.sql  text eol=lf
*.yml  text eol=lf
*.yaml text eol=lf

*.png  binary
*.jpg  binary
*.jpeg binary
*.gif  binary
*.webp binary
*.pdf  binary
*.ico  binary
