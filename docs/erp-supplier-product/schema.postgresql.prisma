// Reference Prisma schema (PostgreSQL) mirroring the MySQL migration in
// database/migrate-supplier-product-erp.js — use when migrating stack to Postgres + Prisma.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum QuoteLineItemType {
  service
  product
}

enum QuoteLineUnitType {
  sq_ft
  linear_ft
  inches
  fixed
  box
  piece
}

model Supplier {
  id           Int       @id @default(autoincrement())
  name         String    @db.VarChar(255)
  contact_name String?   @db.VarChar(255)
  phone        String?   @db.VarChar(64)
  email        String?   @db.VarChar(255)
  address      String?
  notes        String?
  active       Boolean   @default(true)
  created_at   DateTime? @default(now())
  updated_at   DateTime? @updatedAt
  products     Product[]

  @@index([active])
  @@map("suppliers")
}

model Product {
  id          Int       @id @default(autoincrement())
  supplier_id Int
  supplier    Supplier  @relation(fields: [supplier_id], references: [id], onDelete: Restrict)
  name        String    @db.VarChar(255)
  category    String    @db.VarChar(64) // Hardwood, LVP, Engineered, Accessories
  unit_type   String    @default("sq_ft") @db.VarChar(32)
  cost_price  Decimal   @default(0) @db.Decimal(12, 4)
  sku         String?   @db.VarChar(128)
  description String?
  stock_qty   Int?
  active      Boolean   @default(true)
  created_at  DateTime? @default(now())
  updated_at  DateTime? @updatedAt
  quote_items QuoteItem[]

  @@index([supplier_id])
  @@index([category])
  @@index([active])
  @@map("products")
}

model CategoryMarginDefault {
  category            String   @id @db.VarChar(64)
  margin_percentage   Decimal  @db.Decimal(8, 4)
  updated_at          DateTime? @updatedAt

  @@map("category_margin_defaults")
}

model Quote {
  id               Int         @id @default(autoincrement())
  customer_id      Int?
  quote_number     String?     @db.VarChar(64)
  status           String?     @db.VarChar(32)
  subtotal         Decimal?    @db.Decimal(12, 2)
  tax_total        Decimal?    @db.Decimal(12, 2)
  discount_type    String?     @db.VarChar(32)
  discount_value   Decimal?    @db.Decimal(12, 2)
  total_amount     Decimal?    @db.Decimal(12, 2)
  notes            String?
  terms_conditions String?
  service_type     String?     @db.VarChar(128)
  public_token     String?     @db.VarChar(128)
  expiration_date  DateTime?   @db.Date
  items            QuoteItem[]

  @@map("quotes")
}

model QuoteItem {
  id                     Int               @id @default(autoincrement())
  quote_id               Int
  quote                  Quote             @relation(fields: [quote_id], references: [id], onDelete: Cascade)
  description            String?
  quantity               Decimal           @default(0) @db.Decimal(12, 4)
  unit_price             Decimal           @default(0) @db.Decimal(12, 4)
  total_price            Decimal           @default(0) @db.Decimal(12, 4)
  unit_type              QuoteLineUnitType @default(sq_ft)
  type                   String            @default("service") @db.VarChar(32)
  notes                  String?
  service_catalog_id     Int?
  service_type           String?           @db.VarChar(64)
  catalog_customer_notes String?
  sort_order             Int               @default(0)
  item_type              QuoteLineItemType @default(service)
  product_id             Int?
  product                Product?          @relation(fields: [product_id], references: [id], onDelete: SetNull)
  cost_price             Decimal?          @db.Decimal(12, 4)
  markup_percentage      Decimal?          @db.Decimal(8, 4)
  sell_price             Decimal?          @db.Decimal(12, 4)

  @@index([quote_id])
  @@index([product_id])
  @@map("quote_items")
}
