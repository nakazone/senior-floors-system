# Database (MySQL - same as LP/CRM)
DB_HOST=localhost
DB_NAME=your_db_name
DB_USER=your_db_user
DB_PASS=your_db_password

# Server (Railway sets PORT)
PORT=3000

# Session secret (required for authentication)
SESSION_SECRET=your-random-secret-here-change-in-production
# Se o CRM abre num domínio (ex. Vercel) e a API noutro (Railway), defina 1 para cookie SameSite=None + Secure
# SESSION_CROSS_SITE=1

# Notificação no celular (app ntfy) — mesmo nome de tópico que você inscreveu no app
# LEAD_NTFY_TOPIC=seu_topico_secreto
# LEAD_NTFY_URL=https://ntfy.sh

# Opcional: Google Sheets / planilha Meta → POST /api/receive-lead (Apps Script).
# Script de referência (ZIP opcional, coluna ZIP opcional): docs/samples/meta-sheet-sync.gs
# Headers: X-Sheets-Sync: 1 e X-Sheets-Sync-Secret: <mesmo valor>
# Se SHEETS_SYNC_SECRET estiver definido no Railway e o script enviar segredo errado → 401 (leads não entram).
# ZIP: pedidos com form-name Meta ou header acima aceitam ZIP vazio (grava 00000).
# Resposta JSON: duplicate_skipped=true → lead já existia (mesmo email/telefone), não é linha nova.
# Apps Script: o loop deve incluir a última linha (ex.: for (r = 2; r <= lastRow; r++)).
# SHEETS_SYNC_SECRET=...

# Marketing: após deploy rode na Railway (one-off ou release phase):
#   npm run migrate:marketing
# Isso adiciona UTM em `leads` e cria `ad_spend` para CPL/ROI no dashboard Marketing.

# Google Calendar — sincroniza agendamentos de projeto (all-day) e visitas de leads (com hora)
# Passo a passo completo: docs/google-calendar-setup.md
# 1) Google Cloud Console → APIs → Calendar API → OAuth 2.0 Client (Web)
# 2) Redirect URI: https://SEU-CRM.railway.app/api/integrations/google-calendar/callback (e localhost para dev)
# 3) Admin: GET /api/integrations/google-calendar/oauth-url → abrir authUrl → copiar refresh do HTML
# 4) MySQL: rodar database/add-google-calendar-event-ids.sql
# GOOGLE_CALENDAR_CLIENT_ID=
# GOOGLE_CALENDAR_CLIENT_SECRET=
# GOOGLE_CALENDAR_REFRESH_TOKEN=
# GOOGLE_CALENDAR_ID=primary
# GOOGLE_CALENDAR_OAUTH_REDIRECT_URI=https://...
# GOOGLE_CALENDAR_TIMEZONE=America/Chicago
# GOOGLE_CALENDAR_VISIT_DURATION_MINUTES=60
# PUBLIC_CRM_URL=https://SEU-CRM.railway.app

# PDFs de orçamento: após import, o binário fica em quotes.invoice_pdf (recomendado). Rode uma vez:
#   npm run migrate:quote-pdf-blob
# Sem essa coluna, o PDF fica só em ./uploads/quote-pdfs/ — no Railway sem volume perde-se ao redeploy.
