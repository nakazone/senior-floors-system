# Database (MySQL - same as LP/CRM)
# Local com MySQL na máquina: localhost. Railway: host do serviço MySQL (não use localhost para BD remoto).
DB_HOST=seu-host-mysql.railway.app
DB_NAME=nome_do_banco
DB_USER=usuario_mysql
DB_PASS=sua_senha_forte_aqui
#
# Se DATABASE_URL tiver mysql.railway.internal, preencha DB_HOST com o host público (Connect → Public network).
# Com DB_USER, DB_NAME e DB_PASS definidos, a app e os migrates usam DB_* em vez da URL privada (útil no Mac).

# Opcional no portátil: se DATABASE_URL aponta a mysql.railway.internal (só dentro da Railway),
# cole aqui a URL "Public network" do painel MySQL para migrações locais (npm run migrate:*).
# O host tem de ser o público (ex. *.proxy.rlwy.net), NÃO localhost nem mysql.railway.internal.
# DATABASE_PUBLIC_URL=mysql://user:pass@HOST_PUBLICO:PORTA/railway

# Server (Railway sets PORT)
PORT=3000

# Session secret (required for authentication)
SESSION_SECRET=gere-com-node-crypto-randomBytes-32-toString-hex
# Se o CRM abre num domínio (ex. Vercel) e a API noutro (Railway), defina 1 para cookie SameSite=None + Secure
# SESSION_CROSS_SITE=1

# Notificação no celular (app ntfy) — mesmo nome de tópico que você inscreveu no app
# LEAD_NTFY_TOPIC=seu_topico_secreto
# LEAD_NTFY_URL=https://ntfy.sh

# Opcional: Google Sheets / planilha Meta → POST /api/receive-lead (Apps Script).
# Script de referência (ZIP opcional, coluna ZIP opcional): docs/samples/meta-sheet-sync.gs
# Headers: X-Sheets-Sync: 1 e X-Sheets-Sync-Secret: <mesmo valor>
# Se SHEETS_SYNC_SECRET estiver definido no Railway e o script enviar segredo errado → 401 (leads não entram).
# ZIP: pedidos com form-name Meta ou header acima aceitam ZIP vazio (grava 00000).
# Resposta JSON: duplicate_skipped=true → lead já existia (mesmo email/telefone), não é linha nova.
# Apps Script: o loop deve incluir a última linha (ex.: for (r = 2; r <= lastRow; r++)).
# SHEETS_SYNC_SECRET=...
# Opcional: máximo de leads por POST /api/receive-lead-batch (planilha envia 1 UrlFetch por execução).
# RECEIVE_LEAD_BATCH_MAX=150

# Marketing: após deploy rode na Railway (one-off ou release phase):
#   npm run migrate:marketing
# Isso adiciona UTM em `leads` e cria `ad_spend` para CPL/ROI no dashboard Marketing.

# Google Calendar — sincroniza agendamentos de projeto (all-day) e visitas de leads (com hora)
# Passo a passo completo: docs/google-calendar-setup.md
# 1) Google Cloud Console → APIs → Calendar API → OAuth 2.0 Client (Web)
# 2) Redirect URI: https://SEU-CRM.railway.app/api/integrations/google-calendar/callback (e localhost para dev)
# 3) Admin: GET /api/integrations/google-calendar/oauth-url → abrir authUrl → copiar refresh do HTML
# 4) MySQL: rodar database/add-google-calendar-event-ids.sql
# GOOGLE_CALENDAR_CLIENT_ID=
# GOOGLE_CALENDAR_CLIENT_SECRET=
# GOOGLE_CALENDAR_REFRESH_TOKEN=
# GOOGLE_CALENDAR_ID=primary
# GOOGLE_CALENDAR_OAUTH_REDIRECT_URI=https://...
# GOOGLE_CALENDAR_TIMEZONE=America/Chicago
# GOOGLE_CALENDAR_VISIT_DURATION_MINUTES=60
# PUBLIC_CRM_URL=https://SEU-CRM.railway.app

# On-site quote (mobile): autocompletar morada com Google Places no browser.
# Google Cloud Console → APIs → Maps JavaScript API + Places API → chave restrita por HTTP referrer (domínio do CRM).
# GOOGLE_MAPS_JS_KEY=

# PDFs de orçamento: o binário fica em quotes.invoice_pdf (a app cria a coluna no arranque se faltar).
# Opcional local: npm run migrate:quote-pdf-blob
# Orçamentos antigos só com ficheiro em disco perdido: volte a importar o PDF (não há cópia na BD).

# Quotes v2 — após deploy: npm run migrate:quotes-module
# PDF no servidor: usa pdf-lib (sem Puppeteer). E-mail de orçamento:
#
# Opção A — Resend (recomendado): verificar domínio em resend.com/domains
# RESEND_API_KEY=re_xxxxxxxx
# RESEND_FROM_EMAIL=Senior Floors <quotes@seudominio.com>
# Opcional: RESEND_REPLY_TO=contact@seudominio.com
#
# Opção B — SMTP (Gmail app password, SendGrid, etc.) se não usar Resend:
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_SECURE=false
# SMTP_USER=seu@gmail.com
# SMTP_PASS=app-password
# SMTP_FROM=Senior Floors <seu@gmail.com>
#
# Remetente genérico (se não definir RESEND_FROM_EMAIL / SMTP_FROM):
# CRM_FROM_EMAIL=Senior Floors <quotes@seudominio.com>
#
# Link público no e-mail / PDF:
# PUBLIC_CRM_URL=https://seu-crm.railway.app
#
# Diagnóstico: GET /api/health/email → { ready, resend, smtp }
